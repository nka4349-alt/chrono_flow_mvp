# frozen_string_literal: true

Rails.application.routes.draw do
  root 'home#index'

  get '/login',  to: 'sessions#new'
  post '/login', to: 'sessions#create'
  delete '/logout', to: 'sessions#destroy'

  # HTML（画面）側：グループ作成/編集（親指定）
  resources :groups, only: %i[new create edit update destroy] do
    member { patch :reorder }
  end

  namespace :api do
    # Group calendar events (FullCalendar)
    get "groups/:id/events", to: "group_events#index"

    # Group members sidebar
    get   "groups/:id/members", to: "group_members#index"
    patch "groups/:id/members/:user_id/role", to: "group_members#update_role"
    # === CF_NEXT_TASKS_ROUTES_INNER ===
    # Friends sidebar (home)
    resources :friends, only: %i[index]

    # Event chat (event context)
    resources :events, only: [] do
      resources :chat_messages, only: %i[index create]
    end

    # Direct chat (DM / user context)
    resources :users, only: [] do
      resources :chat_messages, only: %i[index create]
    end
    # === END CF_NEXT_TASKS_ROUTES_INNER ===

    # 個人/参加イベント
    resources :events, only: %i[index show create update destroy] do
      member do
        post :share_to_groups
        post :add_to_my_calendar
    patch 'groups/:id/members/:user_id/role', to: 'group_members#update_role'
      end
    end

    resources :event_requests, only: %i[create update]

    resources :notifications, only: %i[index] do
      member { patch :read }
    end

    # ★ ここが今回の本丸：左ツリー表示に必要
    resources :groups, only: %i[index create update destroy] do
      member do
        patch :reorder
        get :events # /api/groups/:id/events
      end

      # /api/groups/:group_id/chat_messages
      resources :chat_messages, only: %i[index create]
    end

    # /api/groups/:id/members
    get 'groups/:id/members', to: 'group_members#index'
  end
end

