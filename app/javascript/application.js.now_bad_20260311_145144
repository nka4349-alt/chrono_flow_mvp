    // submit handler
    var submitBtn = modal.querySelector('#cf-share-submit');
    if (submitBtn._cfHandler) submitBtn.removeEventListener('click', submitBtn._cfHandler);

    submitBtn._cfHandler = async function () {
      var groupIds = Array.from(modal.querySelectorAll('input[type="checkbox"][data-kind="group"]:checked')).map(function (el) { return Number(el.value); });
      var userIds = Array.from(modal.querySelectorAll('input[type="checkbox"][data-kind="user"]:checked')).map(function (el) { return Number(el.value); });

      if (!groupIds.length && !userIds.length) {
        alert('共有先を選択してください');
        return;
