/* === CF_EVENT_CHAT_TITLE_LABEL ===
   Eventチャットの見出しが (Event#123) になっている場合に、イベント名へ置き換えます。
   #cf-chat-scope の表示を監視して /api/events/:id から title を取得します。
*/
document.addEventListener('DOMContentLoaded', () => {
  const scopeEl = document.getElementById('cf-chat-scope');
  if (!scopeEl) return;

  const titleCache = new Map(); // id -> title
  let lastId = null;

  async function fetchEventTitle(id) {
    if (!id) return null;
    if (titleCache.has(id)) return titleCache.get(id);

    try {
      const res = await fetch(`/api/events/${id}`.replace(/\/+/, '/'), {
        method: 'GET',
        headers: { 'Accept': 'application/json' },
        credentials: 'same-origin'
      });
      if (!res.ok) return null;
      const data = await res.json().catch(() => null);
      const title =
        (data && data.event && data.event.title) ||
        (data && data.title) ||
        null;
      if (title) titleCache.set(id, String(title));
      return title ? String(title) : null;
    } catch (e) {
      return null;
    }
  }

  async function refreshLabel() {
    const text = (scopeEl.textContent || '').trim();
    const m = text.match(/Event#\s*(\d+)/);
    if (!m) return;

    const id = m[1];
    if (!id) return;

    // 同じIDでキャッシュ済みなら即置き換え
    if (id === lastId && titleCache.has(id)) {
      scopeEl.textContent = `（${titleCache.get(id)}）`;
      return;
    }
    lastId = id;

    const title = await fetchEventTitle(id);
    if (title) scopeEl.textContent = `（${title}）`;
  }

  // 初期表示と、以降の表示変更を監視
  refreshLabel();
  const obs = new MutationObserver(() => { refreshLabel(); });
  obs.observe(scopeEl, { childList: true, characterData: true, subtree: true });
});
/* === END CF_EVENT_CHAT_TITLE_LABEL === */

/* === CF_EVENT_SHARE_REQUESTS_V1 ===
 * - Event edit modal: add "共有" button
 * - Share requests panel (approve/reject)
 * - Chat scope label: Event#ID -> Event title
 */
(function () {
  if (window.__CF_EVENT_SHARE_REQUESTS_V1__) return;
  window.__CF_EVENT_SHARE_REQUESTS_V1__ = true;

  function getCsrfToken() {
    var el = document.querySelector('meta[name="csrf-token"]');
    return el ? el.getAttribute('content') : null;
  }

  async function apiFetchCompat(path, opts) {
    // Prefer existing apiFetch (already handles CSRF + JSON)
    if (typeof window.apiFetch === 'function') return window.apiFetch(path, opts || {});

    var method = (opts && opts.method) || 'GET';
    var body = (opts && opts.body) || null;
    var headers = { Accept: 'application/json' };
    var csrf = getCsrfToken();
    if (csrf) headers['X-CSRF-Token'] = csrf;
    if (body !== null) headers['Content-Type'] = 'application/json';

    var res = await fetch(path, {
      method: method,
      headers: headers,
      body: body !== null ? JSON.stringify(body) : null,
      credentials: 'same-origin'
    });

    var isJson = (res.headers.get('content-type') || '').includes('application/json');
    var data = isJson ? await res.json().catch(function () { return null; }) : null;

    if (!res.ok) {
      var msg = data && (data.error || data.message) ? (data.error || data.message) : ('HTTP ' + res.status);
      var err = new Error(msg);
      err.status = res.status;
      err.data = data;
      throw err;
    }
    return data;
  }

  function esc(s) {
    return String(s ?? '').replace(/[&<>"']/g, function (c) {
      return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c];
    });
  }

  // ---------------------------
  // 1) Event chat label fix
  // ---------------------------
  function attachChatScopeObserver() {
    var scopeEl = document.getElementById('cf-chat-scope') || document.getElementById('chat-scope');
    if (!scopeEl) return;

    var inflight = null;

    async function replaceIfNeeded() {
      var txt = (scopeEl.textContent || '').trim();
      var m = txt.match(/Event#(\d+)/);
      if (!m) return;
      var eventId = m[1];
      if (inflight === eventId) return;
      inflight = eventId;
      try {
        var data = await apiFetchCompat('/api/events/' + eventId);
        var ev = data && (data.event || data);
        var title = ev && ev.title ? String(ev.title) : null;
        if (title) {
          // "(Event#12)" -> "(イベント: タイトル)" 風に置換
          scopeEl.textContent = txt.replace(/Event#\d+/, title);
        }
      } catch (e) {
        // ignore
      } finally {
        inflight = null;
      }
    }

    var mo = new MutationObserver(function () { replaceIfNeeded(); });
    mo.observe(scopeEl, { childList: true, characterData: true, subtree: true });
    replaceIfNeeded();
  }

  // ---------------------------
  // 2) Share button in event modal
  // ---------------------------
  function findEventModal() {
    return (
      document.getElementById('cf-event-modal') ||
      document.getElementById('event-modal') ||
      document.querySelector('.cf-modal[data-modal="event"]') ||
      null
    );
  }

  function extractEventIdFromModal(modal) {
    if (!modal) return null;

    // 1) dataset
    var ds = modal.dataset || {};
    if (ds.eventId) return String(ds.eventId);

    // 2) hidden input
    var hid = modal.querySelector('input[type="hidden"][name="event_id"], input[type="hidden"]#event-id');
    if (hid && hid.value) return String(hid.value);

    // 3) meta text like "event_id=9"
    var meta = modal.querySelector('#cf-ev-meta') || modal.querySelector('.cf-ev-meta') || null;
    if (meta) {
      var m = (meta.textContent || '').match(/event_id\s*=\s*(\d+)/i);
      if (m) return String(m[1]);
    }

    // 4) title area includes "Event#id" etc
    var m2 = (modal.textContent || '').match(/event_id\s*=\s*(\d+)/i);
    if (m2) return String(m2[1]);

    return null;
  }

  function ensureShareModal() {
    var m = document.getElementById('cf-share-modal');
    if (m) return m;

    m = document.createElement('div');
    m.id = 'cf-share-modal';
    m.className = 'cf-modal hidden';
    m.innerHTML = [
      '<div class="cf-modal-backdrop" data-close="1"></div>',
      '<div class="cf-modal-panel" style="max-width:720px;">',
      '  <div class="cf-modal-header">',
      '    <strong>イベント共有</strong>',
      '    <button type="button" class="cf-btn small" data-close="1">×</button>',
      '  </div>',
      '  <div class="cf-modal-body">',
      '    <div class="cf-muted" id="cf-share-hint" style="margin-bottom:8px;"></div>',
      '    <div class="cf-grid-2">',
      '      <div>',
      '        <div class="cf-section-title">共有先グループ</div>',
      '        <div id="cf-share-groups" class="cf-share-list"></div>',
      '      </div>',
      '      <div>',
      '        <div class="cf-section-title">共有先ユーザー（メンバー/フレンド）</div>',
      '        <div id="cf-share-users" class="cf-share-list"></div>',
      '      </div>',
      '    </div>',
      '    <div class="cf-modal-actions" style="gap:8px; margin-top:12px;">',
      '      <button id="cf-share-submit" class="cf-btn" type="button">共有リクエスト送信</button>',
      '      <button class="cf-btn" type="button" data-close="1">閉じる</button>',
      '    </div>',
      '  </div>',
