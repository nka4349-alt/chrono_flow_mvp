            }
          } catch (e) {
            console.error(e);
            alert('更新に失敗しました: ' + e.message);
          } finally {
            btn.disabled = false;
          }
        });
      });
    } catch (e) {
      body.innerHTML = '<div class="cf-muted">読み込み失敗: ' + esc(e.message) + '</div>';
    }
  }

  function boot() {
    attachChatScopeObserver();
    attachEventModalObserver();

