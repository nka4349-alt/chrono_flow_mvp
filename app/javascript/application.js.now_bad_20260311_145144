// ChronoFlow MVP front (patch v3)
// - Restores group events endpoint usage (/api/groups/:id/events)
// - Restores VSCode-like group tree (collapse + add/edit)
// - Restores members panel + role select
// - Adds friends list on personal calendar
// - Adds event chat context (/api/events/:id/chat_messages)

function getCsrfToken() {
  const el = document.querySelector('meta[name="csrf-token"]');
  return el ? el.getAttribute('content') : null;
}

async function apiFetch(path, { method = 'GET', body = null } = {}) {
  const headers = { 'Accept': 'application/json' };
  const csrf = getCsrfToken();
  if (csrf) headers['X-CSRF-Token'] = csrf;
  if (body !== null) headers['Content-Type'] = 'application/json';

  const res = await fetch(path, {
    method,
    headers,
    body: body !== null ? JSON.stringify(body) : null,
    credentials: 'same-origin'
  });

  const isJson = (res.headers.get('content-type') || '').includes('application/json');
  const data = isJson ? await res.json().catch(() => null) : null;

  if (!res.ok) {
    const msg = (data && (data.error || data.message)) ? `${data.error || data.message}` : `HTTP ${res.status}`;
    const err = new Error(msg);
    err.status = res.status;
    err.data = data;
    throw err;
  }

  return data;
}

function pad2(n) { return String(n).padStart(2, '0'); }

function toLocalInputValue(date) {
  if (!date) return '';
  const d = (date instanceof Date) ? date : new Date(date);
  if (Number.isNaN(d.getTime())) return '';
  return `${d.getFullYear()}-${pad2(d.getMonth() + 1)}-${pad2(d.getDate())}T${pad2(d.getHours())}:${pad2(d.getMinutes())}`;
}

function fromLocalInputValue(str) {
  if (!str) return null;
  const d = new Date(str); // datetime-local is parsed as local time
  if (Number.isNaN(d.getTime())) return null;
  return d.toISOString();
}

function escapeHtml(s) {
  return String(s || '')
    .replaceAll('&', '&amp;')
    .replaceAll('<', '&lt;')
    .replaceAll('>', '&gt;')
    .replaceAll('"', '&quot;')
    .replaceAll("'", '&#039;');
}

function initChronoFlowHome() {
  const root = document.querySelector('.cf-root[data-page="home"]');
  if (!root) return;
  if (root.dataset.cfBooted === '1') return;
  root.dataset.cfBooted = '1';

  const currentUserId = Number(root.dataset.currentUserId || '0');

  // --- State ---
  let mode = 'home'; // 'home' | 'group'
  let selectedGroupId = null;
  let groupsCache = [];

  // chat context
  // { type: 'none'|'group'|'event', groupId?: number, eventId?: number }
  let chatContext = { type: 'none' };
  let chatPollTimer = null;

  // collapsed group ids
  const STORAGE_KEY = 'cf:groupTreeCollapsed:v3';
  let collapsed = {};
  try { collapsed = JSON.parse(localStorage.getItem(STORAGE_KEY) || '{}'); } catch (_) { collapsed = {}; }
  const saveCollapsed = () => {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(collapsed)); } catch (_) {}
  };

  // --- Elements ---
  const groupTreeEl = document.getElementById('cf-group-tree');
  const selectedGroupLabelEl = document.getElementById('cf-selected-group');
  const rightTitleEl = document.getElementById('cf-right-title');
  const membersEl = document.getElementById('cf-members');

  const chatScopeEl = document.getElementById('cf-chat-scope');
  const chatBackBtn = document.getElementById('cf-chat-back');
  const chatMessagesEl = document.getElementById('cf-chat-messages');
  const chatFormEl = document.getElementById('cf-chat-form');
  const chatInputEl = document.getElementById('cf-chat-input');

  const btnModeHome = document.getElementById('cf-mode-home');
  const btnCreateGroup = document.getElementById('cf-create-group');

  // Event modal
  const modalEl = document.getElementById('cf-event-modal');
  const modalTitleEl = document.getElementById('cf-event-modal-title');
  const modalMetaEl = document.getElementById('cf-ev-meta');
  const evTitleEl = document.getElementById('cf-ev-title');
  const evStartEl = document.getElementById('cf-ev-start');
  const evEndEl = document.getElementById('cf-ev-end');
  const evAllDayEl = document.getElementById('cf-ev-all-day');
  const evSaveEl = document.getElementById('cf-ev-save');
  const evDeleteEl = document.getElementById('cf-ev-delete');
  const evAddLinkEl = document.getElementById('cf-ev-add-link');
  const evAddCopyEl = document.getElementById('cf-ev-add-copy');
  const evCloseEl = document.getElementById('cf-event-modal-close');

  let modalEventId = null; // null => create

  function openModal() {
    if (!modalEl) return;
    modalEl.classList.remove('hidden');
  }

  function closeModal() {
    if (!modalEl) return;
    modalEl.classList.add('hidden');
    modalEventId = null;
    if (modalMetaEl) modalMetaEl.textContent = '';
  }

  if (modalEl) {
    modalEl.addEventListener('click', (e) => {
      if (e.target && e.target.dataset && e.target.dataset.close) closeModal();
    });
  }
  if (evCloseEl) evCloseEl.addEventListener('click', closeModal);

  // --- Helpers: group tree ---
  function buildChildrenMap(groups) {
    const map = new Map();
    groups.forEach(g => {
      const pid = (g.parent_id === null || g.parent_id === undefined) ? null : Number(g.parent_id);
      const key = pid === null ? 'root' : String(pid);
      if (!map.has(key)) map.set(key, []);
      map.get(key).push(g);
    });

    for (const [, arr] of map.entries()) {
      arr.sort((a, b) => {
        const ap = (a.position ?? 0);
        const bp = (b.position ?? 0);
        if (ap !== bp) return ap - bp;
        return Number(a.id) - Number(b.id);
      });
    }

    return map;
  }

  function collectSubtreeIds(rootId) {
    const childrenMap = buildChildrenMap(groupsCache);
    const out = new Set([Number(rootId)]);
    const stack = [String(rootId)];
    while (stack.length) {
      const k = stack.pop();
      const kids = childrenMap.get(k) || [];
      for (const child of kids) {
        const cid = Number(child.id);
        if (!out.has(cid)) {
          out.add(cid);
          stack.push(String(child.id));
        }
      }
    }
    return out;
  }

  function flattenGroups(excludeIds = new Set()) {
    const childrenMap = buildChildrenMap(groupsCache);
    const out = [];
    const walk = (parentKey, depth) => {
      const kids = childrenMap.get(parentKey) || [];
      for (const g of kids) {
        const gid = Number(g.id);
        if (!excludeIds.has(gid)) out.push({ group: g, depth });
        walk(String(g.id), depth + 1);
      }
    };
    walk('root', 0);
    return out;
  }

  // --- Group modal ---
  function ensureGroupModal() {
    let modal = document.getElementById('cf-group-modal');
    if (modal) return modal;

    modal = document.createElement('div');
    modal.id = 'cf-group-modal';
    modal.className = 'cf-modal hidden';
    modal.setAttribute('role', 'dialog');
    modal.setAttribute('aria-modal', 'true');

    modal.innerHTML = `
      <div class="cf-modal-backdrop" data-close="1"></div>
      <div class="cf-modal-panel">
        <div class="cf-modal-header">
          <strong id="cf-group-modal-title">グループ</strong>
          <button id="cf-group-modal-close" class="cf-btn small" type="button">×</button>
        </div>
        <div class="cf-modal-body">
          <div class="cf-field">
            <label>グループ名</label>
            <input id="cf-gm-name" type="text" />
          </div>
          <div class="cf-field">
            <label>親グループ</label>
            <select id="cf-gm-parent"></select>
          </div>
          <div class="cf-modal-actions" style="gap:8px;">
            <button id="cf-gm-save" class="cf-btn" type="button">保存</button>
            <button id="cf-gm-cancel" class="cf-btn" type="button">キャンセル</button>
          </div>
          <div id="cf-gm-hint" class="cf-muted" style="margin-top:8px;"></div>
        </div>
      </div>
    `;

    document.body.appendChild(modal);

    const close = () => modal.classList.add('hidden');
    modal.querySelector('[data-close="1"]').addEventListener('click', close);
    modal.querySelector('#cf-group-modal-close').addEventListener('click', close);
    modal.querySelector('#cf-gm-cancel').addEventListener('click', close);

    return modal;
  }

  async function openGroupModal({ formMode = 'create', group = null, parentId = null } = {}) {
    const modal = ensureGroupModal();
    const titleEl = modal.querySelector('#cf-group-modal-title');
    const nameEl = modal.querySelector('#cf-gm-name');
    const parentEl = modal.querySelector('#cf-gm-parent');
    const hintEl = modal.querySelector('#cf-gm-hint');
    const saveBtn = modal.querySelector('#cf-gm-save');

    const isEdit = formMode === 'edit';

    titleEl.textContent = isEdit ? 'グループ編集' : 'グループ作成';
    hintEl.textContent = isEdit ? '名前/親を変更できます（自分自身や子孫は親にできません）' : '名前と親を選んで作成します';

    nameEl.value = isEdit ? (group?.name || '') : '';

    // parent options
    parentEl.innerHTML = '';
    const rootOpt = document.createElement('option');
    rootOpt.value = '';
    rootOpt.textContent = '（ルート）';
    parentEl.appendChild(rootOpt);

    let exclude = new Set();
    if (isEdit && group) exclude = collectSubtreeIds(group.id);

    const rows = flattenGroups(exclude);
    for (const row of rows) {
      const opt = document.createElement('option');
      opt.value = String(row.group.id);
      const dash = '—'.repeat(row.depth);
      opt.textContent = (dash ? (dash + ' ') : '') + row.group.name;
      parentEl.appendChild(opt);
    }

    const defaultParent = isEdit
      ? (group?.parent_id ? String(group.parent_id) : '')
      : (parentId ? String(parentId) : ((mode === 'group' && selectedGroupId) ? String(selectedGroupId) : ''));

    parentEl.value = defaultParent;

    const handler = async () => {
      const name = (nameEl.value || '').trim();
      if (!name) { alert('グループ名を入力してください'); nameEl.focus(); return; }
      const pid = parentEl.value ? Number(parentEl.value) : null;

      saveBtn.disabled = true;
      try {
        let result = null;
        if (isEdit && group) {
          result = await apiFetch('/api/groups/' + group.id, {
            method: 'PATCH',
            body: { group: { name: name, parent_id: pid } }
          });
        } else {
          result = await apiFetch('/api/groups', {
            method: 'POST',
            body: { group: { name: name, parent_id: pid } }
          });
        }

        modal.classList.add('hidden');
        await loadGroups();

        const createdId = (!isEdit && result && (result.group?.id || result.id))
          ? Number(result.group?.id || result.id)
          : null;

        if (createdId) {
          await selectGroup(createdId);
        } else {
          renderGroupTree();
        }
      } catch (err) {
        console.error(err);
        alert('保存に失敗しました（権限/入力/サーバログを確認してください）');
      } finally {
        saveBtn.disabled = false;
      }
    };

    if (saveBtn._cfHandler) saveBtn.removeEventListener('click', saveBtn._cfHandler);
    saveBtn._cfHandler = handler;
    saveBtn.addEventListener('click', handler);

    modal.classList.remove('hidden');
    setTimeout(() => { try { nameEl.focus(); } catch (_) {} }, 0);
  }

  // --- Group tree render (VSCode-like) ---
  function renderGroupTree() {
    if (!groupTreeEl) return;
    groupTreeEl.innerHTML = '';

    const childrenMap = buildChildrenMap(groupsCache);

    const renderNodes = (parentKey, depth) => {
      const kids = childrenMap.get(parentKey) || [];
      for (const g of kids) {
        const gid = Number(g.id);
        const hasKids = (childrenMap.get(String(g.id)) || []).length > 0;
        const isCollapsed = !!collapsed[gid];

        const li = document.createElement('li');
        li.className = 'cf-tree-item';
        li.dataset.groupId = String(gid);
        if (mode === 'group' && Number(selectedGroupId) === gid) li.classList.add('active');

        const indent = document.createElement('span');
        indent.className = 'indent';
        indent.style.width = String(depth * 14) + 'px';

        const toggle = document.createElement('button');
        toggle.type = 'button';
        toggle.className = 'cf-tree-toggle';
        if (!hasKids) {
          toggle.classList.add('placeholder');
          toggle.disabled = true;
          toggle.textContent = '';
        } else {
          toggle.textContent = isCollapsed ? '▶' : '▼';
          toggle.setAttribute('aria-label', isCollapsed ? '展開' : '折りたたみ');
          toggle.addEventListener('click', (e) => {
            e.stopPropagation();
            collapsed[gid] = !collapsed[gid];
            saveCollapsed();
            renderGroupTree();
          });
        }

        const name = document.createElement('span');
        name.className = 'cf-tree-name';
        name.textContent = g.name;

        const actions = document.createElement('span');
        actions.className = 'cf-tree-actions';

        const addBtn = document.createElement('button');
        addBtn.type = 'button';
        addBtn.className = 'cf-tree-action';
        addBtn.title = '子グループを追加';
        addBtn.textContent = '+';
        addBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          openGroupModal({ formMode: 'create', parentId: gid });
        });

        const editBtn = document.createElement('button');
        editBtn.type = 'button';
        editBtn.className = 'cf-tree-action';
        editBtn.title = '編集';
        editBtn.textContent = '✎';
        editBtn.addEventListener('click', (e) => {
          e.stopPropagation();
          openGroupModal({ formMode: 'edit', group: g });
        });

        actions.appendChild(addBtn);
        actions.appendChild(editBtn);

        li.appendChild(indent);
        li.appendChild(toggle);
        li.appendChild(name);
        li.appendChild(actions);

        li.addEventListener('click', () => selectGroup(gid));
        groupTreeEl.appendChild(li);

        if (hasKids && !isCollapsed) {
          renderNodes(String(g.id), depth + 1);
        }
      }
    };

    renderNodes('root', 0);
  }

  // --- Groups API ---
  async function loadGroups() {
    const data = await apiFetch('/api/groups');
    groupsCache = data.groups || [];
    renderGroupTree();
  }

  // --- Members (group) ---
  async function loadMembers() {
    if (!membersEl) return;

    if (!selectedGroupId) {
      membersEl.innerHTML = '';
      return;
    }

    membersEl.innerHTML = '<div class="cf-muted">読み込み中...</div>';

    try {
      const data = await apiFetch(`/api/groups/${selectedGroupId}/members`);

      const members = data.members || [];
      const ownerUserId = data.owner_user_id || data.owner_id || null;
      const canManage = !!data.can_manage_roles;

      if (!members.length) {
        membersEl.innerHTML = '<div class="cf-muted">メンバーがいません</div>';
        return;
      }

      membersEl.innerHTML = '';
      members.forEach(m => {
        const uid = Number(m.user_id || m.id || 0);
        const role = (m.role || 'member').toString();
        const isOwner = (ownerUserId && uid && Number(ownerUserId) === uid) || !!m.is_owner;

        const row = document.createElement('div');
        row.className = 'cf-member-row';

        const left = document.createElement('div');
        left.innerHTML = `
          <div class="cf-member-name">${escapeHtml(m.name || m.email || 'user')}</div>
          <div class="cf-member-role">${escapeHtml(role)}${isOwner ? ' (owner)' : ''}</div>
        `;

        const right = document.createElement('div');
        if (canManage && uid && !isOwner && uid !== Number(currentUserId || 0)) {
          const sel = document.createElement('select');
          sel.className = 'cf-select';
          sel.innerHTML = `
            <option value="member">member</option>
            <option value="admin">admin</option>
          `;
          sel.value = role;
          sel.addEventListener('change', async () => {
            const nextRole = sel.value;
            try {
              await apiFetch(`/api/groups/${selectedGroupId}/members/${uid}/role`, {
                method: 'PATCH',
                body: { role: nextRole }
              });
              await loadMembers();
            } catch (e) {
              alert(`更新に失敗: ${e.message}`);
              sel.value = role;
            }
          });
          right.appendChild(sel);
        }

        row.appendChild(left);
        row.appendChild(right);
        membersEl.appendChild(row);
      });
    } catch (e) {
      membersEl.innerHTML = `<div class="cf-muted">読み込み失敗: ${escapeHtml(e.message)}</div>`;
    }
  }

  // --- Friends (home) ---
  async function loadFriends() {
    if (!membersEl) return;

    membersEl.innerHTML = '<div class="cf-muted">読み込み中...</div>';

    try {
      const data = await apiFetch('/api/friends');
      const friends = data.friends || [];

      if (!friends.length) {
        membersEl.innerHTML = '<div class="cf-muted">フレンドがいません</div>';
        return;
      }

      membersEl.innerHTML = '';
      friends.forEach(f => {
        const row = document.createElement('div');
        row.className = 'cf-friend-row';
        row.innerHTML = `
          <div>
            <div class="cf-member-name">${escapeHtml(f.name || f.email || ('User#' + f.id))}</div>
            <div class="cf-member-role">${escapeHtml(f.email || '')}</div>
          </div>
        `;
        membersEl.appendChild(row);
      });
    } catch (e) {
      // If friends endpoint isn't present yet
      membersEl.innerHTML = `<div class="cf-muted">フレンド取得に失敗: ${escapeHtml(e.message)}</div>`;
    }
  }

  // --- Mode switching ---
  async function selectGroup(groupId) {
    mode = 'group';
    selectedGroupId = Number(groupId);

    const g = groupsCache.find(x => Number(x.id) === Number(selectedGroupId));
    if (selectedGroupLabelEl) selectedGroupLabelEl.textContent = g ? g.name : `Group#${selectedGroupId}`;
    if (rightTitleEl) rightTitleEl.textContent = 'メンバー';

    renderGroupTree();
    await loadMembers();

    setChatContext({ type: 'group', groupId: selectedGroupId });

    if (calendar) calendar.refetchEvents();
  }

  async function selectHome() {
    mode = 'home';
    selectedGroupId = null;

    if (selectedGroupLabelEl) selectedGroupLabelEl.textContent = '未選択';
    if (rightTitleEl) rightTitleEl.textContent = 'フレンド';

    renderGroupTree();
    await loadFriends();

    setChatContext({ type: 'none' });

    if (calendar) calendar.refetchEvents();
  }

  if (btnModeHome) {
    btnModeHome.addEventListener('click', () => {
      selectHome().catch(console.error);
    });
  }

  if (btnCreateGroup) {
    btnCreateGroup.addEventListener('click', (e) => {
      e.preventDefault();
      const pid = (mode === 'group' && selectedGroupId) ? Number(selectedGroupId) : null;
      openGroupModal({ formMode: 'create', parentId: pid }).catch(console.error);
    });
  }

  // --- Chat ---
  function stopChatPoll() {
    if (chatPollTimer) {
      clearInterval(chatPollTimer);
      chatPollTimer = null;
    }
  }

  function chatEndpointFor(ctx) {
    if (!ctx || ctx.type === 'none') return null;
    if (ctx.type === 'group' && ctx.groupId) return `/api/groups/${ctx.groupId}/chat_messages`;
    if (ctx.type === 'event' && ctx.eventId) return `/api/events/${ctx.eventId}/chat_messages`;
    return null;
  }

  function updateChatHeader() {
    if (!chatScopeEl) return;

    if (chatContext.type === 'none') {
      chatScopeEl.textContent = '（グループ未選択）';
      if (chatBackBtn) chatBackBtn.classList.add('hidden');
      return;
    }

    if (chatContext.type === 'group') {
      const g = groupsCache.find(x => Number(x.id) === Number(chatContext.groupId));
      chatScopeEl.textContent = g ? `（${g.name}）` : `（Group#${chatContext.groupId}）`;
      if (chatBackBtn) chatBackBtn.classList.add('hidden');
      return;
    }

    if (chatContext.type === 'event') {
      chatScopeEl.textContent = `（Event#${chatContext.eventId}）`;
      if (chatBackBtn) {
        if (mode === 'group' && selectedGroupId) chatBackBtn.classList.remove('hidden');
        else chatBackBtn.classList.add('hidden');
      }
    }
  }

  async function loadChatMessages() {
    const ep = chatEndpointFor(chatContext);
    if (!ep) return;

    const data = await apiFetch(`${ep}?limit=80`);
    const msgs = data.messages || [];

    if (!chatMessagesEl) return;
    chatMessagesEl.innerHTML = '';

    msgs.forEach(m => {
      const p = document.createElement('p');
      p.className = 'cf-chat-line';
      const t = m.created_at ? new Date(m.created_at) : null;
      const at = t && !Number.isNaN(t.getTime()) ? `${pad2(t.getHours())}:${pad2(t.getMinutes())}` : '';
      p.innerHTML = `<span class="who">${escapeHtml(m.user_name || 'user')}</span><span class="at">${escapeHtml(at)}</span>：${escapeHtml(m.body)}`;
      chatMessagesEl.appendChild(p);
    });

    chatMessagesEl.scrollTop = chatMessagesEl.scrollHeight;
  }

  function startChatPoll() {
    stopChatPoll();

    const ep = chatEndpointFor(chatContext);
    if (!ep) {
      if (chatMessagesEl) chatMessagesEl.innerHTML = '';
      return;
    }

    loadChatMessages().catch(() => {});
    chatPollTimer = setInterval(() => loadChatMessages().catch(() => {}), 5000);
  }

  function setChatContext(ctx) {
    chatContext = ctx || { type: 'none' };
    updateChatHeader();
    startChatPoll();
  }

  if (chatBackBtn) {
    chatBackBtn.addEventListener('click', () => {
      if (mode === 'group' && selectedGroupId) {
        setChatContext({ type: 'group', groupId: Number(selectedGroupId) });
      }
    });
  }

  if (chatFormEl) {
    chatFormEl.addEventListener('submit', async (e) => {
      e.preventDefault();
      const text = (chatInputEl?.value || '').trim();
      if (!text) return;

      const ep = chatEndpointFor(chatContext);
      if (!ep) {
        alert('チャットの対象を選択してください');
        return;
      }

      try {
        await apiFetch(ep, { method: 'POST', body: { body: text } });
        if (chatInputEl) chatInputEl.value = '';
        await loadChatMessages();
      } catch (err) {
        alert(`送信に失敗: ${err.message}`);
      }
    });
  }

  // --- Calendar ---
  const calendarEl = document.getElementById('cf-calendar');
  let calendar = null;

  function ensureFullCalendarReady() {
    return typeof window.FullCalendar !== 'undefined' && window.FullCalendar && window.FullCalendar.Calendar;
  }

  function initCalendar() {
    if (!calendarEl) return;
    if (!ensureFullCalendarReady()) return;
    if (calendar) return;

    calendar = new window.FullCalendar.Calendar(calendarEl, {
      initialView: 'dayGridMonth',
      height: '100%',
      headerToolbar: {
        left: 'prev,next today',
        center: 'title',
        right: 'dayGridMonth,dayGridWeek,timeGridWeek,timeGridDay'
      },
      nowIndicator: true,
      selectable: true,
      eventTimeFormat: { hour: '2-digit', minute: '2-digit', hour12: false },

      // TimeGrid options (Day/Week schedule)
      slotMinTime: '06:00:00',
      slotMaxTime: '24:00:00',
      slotDuration: '00:30:00',
      slotEventOverlap: false,
      eventMaxStack: 12,
      expandRows: true,
      eventDisplay: 'block',

      views: {
        timeGridDay: { slotEventOverlap: false, eventMaxStack: 12 },
        timeGridWeek: { slotEventOverlap: false, eventMaxStack: 12 }
      },

      events: async (fetchInfo, success, failure) => {
        try {
          const params = new URLSearchParams();
          params.set('start', fetchInfo.startStr);
          params.set('end', fetchInfo.endStr);

          let data;
          if (mode === 'group' && selectedGroupId) {
            data = await apiFetch(`/api/groups/${selectedGroupId}/events?${params.toString()}`);
          } else {
            params.set('scope', 'home');
            data = await apiFetch(`/api/events?${params.toString()}`);
          }

          const evs = Array.isArray(data) ? data : ((data && data.events) ? data.events : []);
          success(evs);
        } catch (err) {
          console.error(err);
          failure(err);
        }
      },

      dateClick: (info) => {
        openCreateModal(info.date);
      },

      eventClick: (info) => {
        openEditModal(info.event);
        // switch chat to event context
        setChatContext({ type: 'event', eventId: Number(info.event.id) });
      }
    });

    calendar.render();
  }

  // --- Event modal handlers ---
  function openCreateModal(date) {
    modalEventId = null;
    if (modalTitleEl) modalTitleEl.textContent = 'イベント作成';

    if (evTitleEl) evTitleEl.value = '';
    if (evStartEl) evStartEl.value = toLocalInputValue(date);

    const endDate = new Date(date);
    endDate.setHours(endDate.getHours() + 1);
    if (evEndEl) evEndEl.value = toLocalInputValue(endDate);

    if (evAllDayEl) evAllDayEl.checked = false;

    if (evDeleteEl) evDeleteEl.style.display = 'none';
    if (evAddLinkEl) evAddLinkEl.style.display = 'none';
    if (evAddCopyEl) evAddCopyEl.style.display = 'none';

    if (modalMetaEl) {
      modalMetaEl.textContent = (mode === 'group' && selectedGroupId)
        ? `作成先：グループ（id=${selectedGroupId}）`
        : '作成先：個人';
    }

    openModal();
  }

  function openEditModal(fcEvent) {
    modalEventId = Number(fcEvent.id);
    if (modalTitleEl) modalTitleEl.textContent = 'イベント編集';

    if (evTitleEl) evTitleEl.value = fcEvent.title || '';
    if (evStartEl) evStartEl.value = toLocalInputValue(fcEvent.start);
    if (evEndEl) evEndEl.value = toLocalInputValue(fcEvent.end);
    if (evAllDayEl) evAllDayEl.checked = !!fcEvent.allDay;

    if (evDeleteEl) evDeleteEl.style.display = 'inline-block';
    if (evAddLinkEl) evAddLinkEl.style.display = 'inline-block';
    if (evAddCopyEl) evAddCopyEl.style.display = 'inline-block';

    const ext = fcEvent.extendedProps || {};
    const gids = Array.isArray(ext.group_ids) ? ext.group_ids : [];
    if (modalMetaEl) modalMetaEl.textContent = `event_id=${modalEventId} / groups=${gids.join(',')}`;

    openModal();
  }

  if (evSaveEl) {
    evSaveEl.addEventListener('click', async () => {
      const title = (evTitleEl?.value || '').trim();
      if (!title) { alert('タイトルは必須です'); return; }

      const payload = {
        event: {
          title,
          start_at: fromLocalInputValue(evStartEl?.value),
          end_at: fromLocalInputValue(evEndEl?.value),
          all_day: !!(evAllDayEl?.checked)
        }
      };

      // When creating while group is selected, attach to that group
      if (mode === 'group' && selectedGroupId && modalEventId === null) {
        payload.group_ids = [Number(selectedGroupId)];
      }

      try {
        if (modalEventId === null) {
          await apiFetch('/api/events', { method: 'POST', body: payload });
        } else {
          await apiFetch(`/api/events/${modalEventId}`, { method: 'PATCH', body: payload });
        }

        closeModal();
        if (calendar) calendar.refetchEvents();
      } catch (e) {
        alert(`保存に失敗: ${e.message}`);
      }
    });
  }

  if (evDeleteEl) {
    evDeleteEl.addEventListener('click', async () => {
      if (!modalEventId) return;
      if (!confirm('削除しますか？')) return;

      try {
        await apiFetch(`/api/events/${modalEventId}`, { method: 'DELETE' });
        closeModal();
        if (calendar) calendar.refetchEvents();
      } catch (e) {
        alert(`削除に失敗: ${e.message}`);
      }
    });
  }

  if (evAddLinkEl) {
    evAddLinkEl.addEventListener('click', async () => {
      if (!modalEventId) return;
      try {
        await apiFetch(`/api/events/${modalEventId}/add_to_my_calendar`, {
          method: 'POST',
          body: { mode: 'link' }
        });
        alert('取り込みました（リンク）');
        if (calendar) calendar.refetchEvents();
      } catch (e) {
        alert(`取り込みに失敗: ${e.message}`);
      }
    });
  }

  if (evAddCopyEl) {
    evAddCopyEl.addEventListener('click', async () => {
      if (!modalEventId) return;
      try {
        await apiFetch(`/api/events/${modalEventId}/add_to_my_calendar`, {
          method: 'POST',
          body: { mode: 'copy' }
        });
        alert('取り込みました（コピー）');
        closeModal();
        if (calendar) calendar.refetchEvents();
      } catch (e) {
        alert(`取り込みに失敗: ${e.message}`);
      }
    });
  }

  // --- Boot sequence ---
  (async () => {
    try {
      // calendar first (so UI is present even if API fails)
      const t0 = Date.now();
      const waitTimer = setInterval(() => {
        if (ensureFullCalendarReady() || (Date.now() - t0 > 3000)) {
          clearInterval(waitTimer);
          initCalendar();
        }
      }, 50);

      await loadGroups();
      await selectHome();
    } catch (e) {
      console.error(e);
      alert('初期化に失敗しました。ログイン状態とサーバログを確認してください。');
    }
  })();
}

