  async function openShareModal(eventId) {
    var modal = ensureShareModal();
    modal.classList.remove('hidden');

    var hint = modal.querySelector('#cf-share-hint');
    hint.textContent = '読み込み中...';

    var groupsBox = modal.querySelector('#cf-share-groups');
    var usersBox = modal.querySelector('#cf-share-users');

    groupsBox.innerHTML = '';
    usersBox.innerHTML = '';

    // load event title
    try {
      var evData = await apiFetchCompat('/api/events/' + eventId);
      var ev = evData && (evData.event || evData);
      if (ev && ev.title) hint.textContent = 'イベント: ' + ev.title;
      else hint.textContent = 'イベントID: ' + eventId;
    } catch (e) {
      hint.textContent = 'イベントID: ' + eventId;
    }

    // load groups
    var groups = [];
    try {
      var gData = await apiFetchCompat('/api/groups');
      groups = gData && (gData.groups || gData) ? (gData.groups || gData) : [];
    } catch (e) {
      groups = [];
    }

    // load friends
    var friends = [];
    try {
      var fData = await apiFetchCompat('/api/friends');
      friends = fData && (fData.friends || fData) ? (fData.friends || fData) : [];
    } catch (e) {
      friends = [];
    }

    // load group members for selected group (if any)
    var selectedGroupId = window.CF_SELECTED_GROUP_ID || null;
    if (!selectedGroupId) {
      var sg = document.getElementById('cf-selected-group');
      if (sg && sg.dataset && sg.dataset.groupId) selectedGroupId = sg.dataset.groupId;
    }

    var members = [];
    if (selectedGroupId) {
      try {
        var mData = await apiFetchCompat('/api/groups/' + selectedGroupId + '/members');
        members = (mData && mData.members) ? mData.members : [];
      } catch (e) {
        members = [];
      }
    }

    // Render groups
    if (!groups.length) {
      groupsBox.innerHTML = '<div class="cf-muted">グループなし</div>';
    } else {
      groupsBox.innerHTML = groups
        .map(function (g) {
          return (
            '<label class="cf-check"><input type="checkbox" data-kind="group" value="' + esc(g.id) + '" /> ' + esc(g.name || ('Group#' + g.id)) + '</label>'
          );
        })
        .join('');
    }

    // Merge users (members + friends) unique
    var userMap = new Map();
    members.forEach(function (m) {
      var uid = Number(m.user_id || m.id);
      if (!uid) return;
      var name = m.name || m.email || ('User#' + uid);
      userMap.set(uid, { id: uid, name: name, tag: 'member' });
    });
    friends.forEach(function (f) {
      var uid = Number(f.id || f.user_id);
      if (!uid) return;
      var name = f.name || f.email || ('User#' + uid);
      if (!userMap.has(uid)) userMap.set(uid, { id: uid, name: name, tag: 'friend' });
    });

    var users = Array.from(userMap.values());

    if (!users.length) {
      usersBox.innerHTML = '<div class="cf-muted">メンバー/フレンドなし</div>';
    } else {
      usersBox.innerHTML = users
        .map(function (u) {
          var suffix = u.tag ? (' <span class="cf-muted">(' + esc(u.tag) + ')</span>') : '';
          return (
            '<label class="cf-check"><input type="checkbox" data-kind="user" value="' + esc(u.id) + '" /> ' + esc(u.name) + suffix + '</label>'
          );
