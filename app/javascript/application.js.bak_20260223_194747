// month表示のセルを「幅に合わせて正方形」っぽくする
const adjustMonthSquares = () => {
  if (!calendar) return;
  if (calendar.view.type !== "dayGridMonth") return;

  const root = document.getElementById("cf-calendar") || document.getElementById("calendar");
  const grid = root && root.querySelector(".fc-scrollgrid");
  if (!grid) return;

  const gridW = grid.getBoundingClientRect().width;
  const cellW = gridW / 7;

  // activeStart/activeEnd から「何週表示か」を計算（5週/月もあり得るので固定にしない）
  const ms = calendar.view.activeEnd - calendar.view.activeStart;
  const weeks = Math.round(ms / (7 * 24 * 60 * 60 * 1000));

  calendar.setOption("contentHeight", Math.round(cellW * weeks));
};

