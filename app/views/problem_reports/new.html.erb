<div class="cf-report-page">
  <div class="cf-report-card cf-report-card-compact">
    <h1>問題報告</h1>
    <p class="cf-muted">不具合や違和感を送信できます。</p>

    <% if flash[:alert].present? %>
      <div class="cf-form-error"><%= flash[:alert] %></div>
    <% end %>

    <%= form_with model: @problem_report, local: true, class: 'cf-report-form' do |form| %>
      <div class="cf-field">
        <label>件名</label>
        <%= form.text_field :subject, placeholder: '例: AI候補の興味なしが反応しない' %>
      </div>

      <div class="cf-field">
        <label>内容</label>
        <%= form.text_area :body, rows: 6, placeholder: '何をしたら、どうなったかを書いてください。' %>
      </div>

      <div class="cf-modal-actions">
        <%= form.submit '送信', class: 'cf-btn' %>
        <%= link_to '戻る', root_path, class: 'cf-btn' %>
      </div>
    <% end %>
  </div>
</div>
