<div class="cf-admin-page">
  <%= render 'admin/shared/nav' %>
  <div class="cf-admin-header">
    <div><h1>AI失敗ログ</h1><p>failed / timeout / fallback を優先表示します。Railsが200でもAI fallbackならここに残ります。</p></div>
    <div class="cf-admin-range">
      <% %w[24h 7d 30d 90d].each do |range| %>
        <%= link_to range, admin_ai_failures_path(range: range), class: "cf-admin-chip #{'active' if @range == range}" %>
      <% end %>
    </div>
  </div>

  <table class="cf-admin-table">
    <thead><tr><th>ID</th><th>時刻</th><th>状態</th><th>provider</th><th>route</th><th>error</th><th>ユーザー</th></tr></thead>
    <tbody>
      <% @events.each do |event| %>
        <tr>
          <td><%= link_to event.id, admin_ai_usage_event_path(event) %></td>
          <td><%= l(event.created_at, format: :short) rescue event.created_at %></td>
          <td><%= event.status %></td>
          <td><%= event.provider %></td>
          <td><%= event.route %></td>
          <td><%= [event.error_class, event.error_message].compact.join(': ').truncate(120) %></td>
          <td><%= event.user&.email %></td>
        </tr>
      <% end %>
    </tbody>
  </table>
</div>
