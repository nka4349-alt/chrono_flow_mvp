<div class="cf-admin-page">
  <%= render 'admin/shared/nav' %>
  <h1>問題報告 #<%= @report.id %></h1>

  <section class="cf-admin-panel">
    <table class="cf-admin-table cf-admin-detail-table">
      <tbody>
        <tr><th>status</th><td><%= @report.status %></td></tr>
        <tr><th>priority</th><td><%= @report.priority %></td></tr>
        <tr><th>category</th><td><%= @report.category %></td></tr>
        <tr><th>subject</th><td><%= @report.subject %></td></tr>
        <tr><th>user</th><td><%= @report.user&.email %></td></tr>
        <tr><th>page_url</th><td><%= @report.page_url %></td></tr>
        <tr><th>request_id</th><td><%= @report.request_id %></td></tr>
        <tr><th>ai_usage_event</th><td><%= @report.ai_usage_event ? link_to(@report.ai_usage_event_id, admin_ai_usage_event_path(@report.ai_usage_event)) : '-' %></td></tr>
        <tr><th>ai_recommendation</th><td><%= @report.ai_recommendation_id || '-' %></td></tr>
        <tr><th>resolved_at</th><td><%= @report.resolved_at || '-' %></td></tr>
      </tbody>
    </table>
  </section>

  <section class="cf-admin-panel">
    <h2>本文</h2>
    <pre class="cf-admin-pre"><%= @report.body %></pre>
  </section>

  <section class="cf-admin-panel">
    <h2>対応更新</h2>
    <%= form_with model: [:admin, @report], method: :patch, local: true, class: 'cf-admin-form' do |form| %>
      <div class="cf-admin-form-row">
        <label>状態</label>
        <%= form.select :status, ProblemReport::STATUSES.map { |value| [value, value] } %>
      </div>
      <div class="cf-admin-form-row">
        <label>優先度</label>
        <%= form.select :priority, ProblemReport::PRIORITIES.map { |value| [value, value] } %>
      </div>
      <div class="cf-admin-form-row">
        <label>カテゴリ</label>
        <%= form.select :category, ProblemReport::CATEGORIES.map { |value| [value, value] } %>
      </div>
      <div class="cf-admin-form-row">
        <label>管理メモ</label>
        <%= form.text_area :admin_notes, rows: 5 %>
      </div>
      <%= form.submit '更新', class: 'cf-btn' %>
    <% end %>
  </section>

  <section class="cf-admin-panel">
    <h2>metadata</h2>
    <pre class="cf-admin-pre"><%= JSON.pretty_generate(@report.metadata || {}) rescue @report.metadata.inspect %></pre>
  </section>
</div>
