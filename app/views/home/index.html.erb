<div class="cf-root" data-page="home" data-current-user-id="<%= current_user.id %>">
  <aside class="cf-sidebar-left">
    <div class="cf-sidebar-header">
      <h2>グループ</h2>
    </div>
    <ul id="cf-group-tree" class="cf-tree"></ul>
  </aside>

  <main class="cf-main">
    <div class="cf-main-header">
      <div class="cf-selected">
        <span class="cf-muted">選択中：</span>
        <strong id="cf-selected-group">個人</strong>
      </div>
      <div class="cf-main-actions">
        <button id="cf-mode-home" class="cf-btn small" type="button">個人</button>
        <button id="cf-create-group" class="cf-btn small" type="button" aria-haspopup="menu" aria-expanded="false">＋</button>
        <button id="cf-open-search" class="cf-btn small" type="button">検索</button>
      </div>
    </div>
    <div id="cf-calendar" class="cf-calendar"></div>
  </main>

  <aside class="cf-sidebar-right" id="cf-right-sidebar">
    <div class="cf-sidebar-header">
      <h2 id="cf-right-title">メンバー</h2>
    </div>
    <div id="cf-members" class="cf-members">未選択</div>
    <div id="cf-share-requests" class="cf-share-requests"></div>
  </aside>


  <div id="cf-mobile-overlay" class="cf-mobile-overlay" aria-hidden="true"></div>

  <div id="cf-mobile-menu" class="cf-mobile-menu" role="menu" aria-label="モバイルメニュー">
    <button id="cf-mobile-menu-home" class="cf-mobile-menu-btn" type="button">個人</button>
    <button id="cf-mobile-menu-groups" class="cf-mobile-menu-btn" type="button">グループ</button>
    <button id="cf-mobile-menu-members" class="cf-mobile-menu-btn" type="button">メンバー</button>
    <button id="cf-mobile-menu-create" class="cf-mobile-menu-btn" type="button">新規グループ</button>
    <button id="cf-mobile-menu-search" class="cf-mobile-menu-btn" type="button">検索</button>
  </div>

  <div class="cf-chatbar">
    <div class="cf-chat-header">
      <span class="cf-muted">チャット：</span>
      <strong id="cf-chat-scope">（グループ未選択）</strong>
      <button id="cf-chat-back" class="cf-btn small hidden" type="button">← グループ</button>
    </div>
    <div id="cf-chat-messages" class="cf-chat-messages"></div>
    <form id="cf-chat-form" class="cf-chat-form">
      <textarea id="cf-chat-input" rows="1" placeholder="メッセージ..."></textarea>
      <button class="cf-btn" type="submit">送信</button>
    </form>
  </div>

  <!-- Event Modal -->
  <div id="cf-event-modal" class="cf-modal hidden">
    <div class="cf-modal-backdrop" data-close="1"></div>
    <div class="cf-modal-panel">
      <div class="cf-modal-header">
        <strong id="cf-event-modal-title">イベント</strong>
        <button id="cf-event-modal-close" class="cf-btn small" type="button" data-close="1">×</button>
      </div>
      <div class="cf-modal-body">
        <div id="cf-ev-meta" class="cf-muted" style="margin-bottom:8px;"></div>

        <div class="cf-field">
          <label>タイトル</label>
          <input id="cf-ev-title" type="text" />
        </div>

        <div class="cf-field-row">
          <div class="cf-field">
            <label>開始</label>
            <input id="cf-ev-start" type="datetime-local" />
          </div>
          <div class="cf-field">
            <label>終了</label>
            <input id="cf-ev-end" type="datetime-local" />
          </div>
        </div>

        <div class="cf-field">
          <label><input id="cf-ev-all-day" type="checkbox" /> 終日</label>
        </div>

        <div class="cf-field-row">
          <div class="cf-field">
            <label>場所</label>
            <input id="cf-ev-location" type="text" />
          </div>
          <div class="cf-field">
            <label>バーの色</label>
            <input id="cf-ev-color" type="hidden" value="#3b82f6" />
          </div>
        </div>

        <div class="cf-field">
          <label>自由記述</label>
          <textarea id="cf-ev-notes" rows="4"></textarea>
        </div>

        <div class="cf-modal-actions">
          <button id="cf-ev-save" class="cf-btn" type="button">保存</button>
          <button id="cf-ev-delete" class="cf-btn danger" type="button">削除</button>
          <button id="cf-ev-add-link" class="cf-btn" type="button">自分のカレンダーに追加（リンク）</button>
          <button id="cf-ev-add-copy" class="cf-btn" type="button">自分のカレンダーに追加（コピー）</button>
          <button id="cf-ev-share" class="cf-btn" type="button">共有</button>
          <button class="cf-btn" type="button" data-close="1">閉じる</button>
        </div>
      </div>
    </div>
  </div>
</div>

<div id="cf-share-modal" class="cf-modal hidden">
  <div class="cf-modal-backdrop" data-close-share="1"></div>
  <div class="cf-modal-panel cf-share-modal-panel">
    <div class="cf-modal-header">
      <strong>共有リクエスト送信</strong>
      <button id="cf-share-modal-close" class="cf-btn small" type="button">×</button>
    </div>
    <div class="cf-modal-body">
      <div class="cf-field">
        <label>共有先グループ</label>
        <div id="cf-share-groups" class="cf-share-list"></div>
      </div>
      <div class="cf-field">
        <label>共有先ユーザー（グループメンバー / フレンド）</label>
        <div id="cf-share-users" class="cf-share-list"></div>
      </div>
      <div class="cf-modal-actions">
        <button id="cf-share-submit" class="cf-btn" type="button">送信</button>
        <button class="cf-btn" type="button" data-close-share="1">閉じる</button>
      </div>
    </div>
  </div>
</div>

<div id="cf-group-modal" class="cf-modal hidden">
  <div class="cf-modal-backdrop" data-close-group="1"></div>
  <div class="cf-modal-panel cf-group-modal-panel">
    <div class="cf-modal-header">
      <strong id="cf-group-modal-title">グループ</strong>
      <button id="cf-group-modal-close" class="cf-btn small" type="button">×</button>
    </div>
    <div class="cf-modal-body">
      <div id="cf-group-modal-hint" class="cf-muted cf-inline-note"></div>

      <div class="cf-field">
        <label>グループ名</label>
        <input id="cf-group-name" type="text" />
      </div>

      <div class="cf-field">
        <label>親グループ</label>
        <select id="cf-group-parent"></select>
      </div>

      <div id="cf-group-modal-error" class="cf-form-error hidden"></div>

      <div id="cf-group-friends-section" class="cf-group-friends-section hidden">
        <div class="cf-field-row">
          <div class="cf-field">
            <label>フレンド検索</label>
            <input id="cf-group-friend-filter" type="search" autocomplete="off" placeholder="名前 / メールで絞り込み" />
          </div>
          <div class="cf-field cf-field-inline-action">
            <label>&nbsp;</label>
            <button id="cf-group-invite" class="cf-btn" type="button">選択したフレンドを招待</button>
          </div>
        </div>
        <div id="cf-group-friend-list" class="cf-search-results"></div>
      </div>

      <div class="cf-modal-actions">
        <button id="cf-group-save" class="cf-btn" type="button">保存</button>
        <button id="cf-group-delete" class="cf-btn danger" type="button">削除</button>
        <button class="cf-btn" type="button" data-close-group="1">閉じる</button>
      </div>
    </div>
  </div>
</div>

<div id="cf-search-modal" class="cf-modal hidden">
  <div class="cf-modal-backdrop" data-close-search="1"></div>
  <div class="cf-modal-panel cf-search-modal-panel">
    <div class="cf-modal-header">
      <strong>検索</strong>
      <button id="cf-search-modal-close" class="cf-btn small" type="button">×</button>
    </div>
    <div class="cf-modal-body">
      <div class="cf-field">
        <label>キーワード</label>
        <input id="cf-search-input" type="search" autocomplete="off" placeholder="グループ名 / ユーザー名 / メール" />
      </div>

      <div class="cf-search-section">
        <div class="cf-search-section-title">グループ検索</div>
        <div id="cf-search-groups" class="cf-search-results"></div>
      </div>

      <div class="cf-search-section">
        <div class="cf-search-section-title">ユーザー検索</div>
        <div id="cf-search-users" class="cf-search-results"></div>
      </div>
    </div>
  </div>
</div>
