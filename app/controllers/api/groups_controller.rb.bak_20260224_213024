# frozen_string_literal: true

module Api
  class GroupsController < BaseController
    def index
      groups = Group.joins(:group_members)
                    .where(group_members: { user_id: current_user.id })
                    .distinct
                    .order(:position, :id)

      render json: {
        groups: groups.map { |g|
          { id: g.id, name: g.name, parent_id: g.parent_id, position: g.position }
        }
      }
    end
  end
end
