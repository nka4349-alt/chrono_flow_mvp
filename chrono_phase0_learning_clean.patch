+def business_signal_level(text: str) -> int:
+    normalized = normalize_text(text)
+    if contains_any(normalized, BUSINESS_STRONG_KEYWORDS):
+        return 2
+    if contains_any(normalized, BUSINESS_SOFT_KEYWORDS):
+        return 1
+    return 0
